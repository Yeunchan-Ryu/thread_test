#define _CRT_SECURE_NO_WARNINGS
#define WIN32_LEAN_AND_MEAN
#include <winsock2.h>
#include <ws2tcpip.h>
#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>
#include <string.h>
#pragma comment(lib, "Ws2_32.lib")

SOCKET instrument_sock = INVALID_SOCKET;

typedef struct {
    double freq;
    double amp;
    double phase;
}DeviceState;

DeviceState currentState;
char sharedCmdBuffer[256];
double pendingValue = 0.0;

HANDLE hSendEvent;
HANDLE hRecvEvent;
CRITICAL_SECTION cs;

void clearInputBuffer() {
    int ch;
    while ((ch = getchar()) != '\n' && ch != EOF);
}

DWORD WINAPI SendThread(LPVOID IpParm) {
    while (true) {
        LARGE_INTEGER start, end, freq;

        WaitForSingleObject(hSendEvent, INFINITE);
        QueryPerformanceCounter(&start);
        QueryPerformanceFrequency(&freq);

        EnterCriticalSection(&cs);
        send(instrument_sock, sharedCmdBuffer, strlen(sharedCmdBuffer), 0);
        LeaveCriticalSection(&cs);

        QueryPerformanceCounter(&end);
        double latency = (double)(end.QuadPart - start.QuadPart) * 1000.0 / freq.QuadPart;
        printf("Send Latency : %.3f ms\n", latency);

        SetEvent(hRecvEvent);
    }
    return 0;
}

DWORD WINAPI RecvThread(LPVOID IpParam) {
    char recvBuffer[256];
    LARGE_INTEGER start, end, freq;

    QueryPerformanceCounter(&start);
    QueryPerformanceCounter(&freq);

    while (true) {
        WaitForSingleObject(hRecvEvent, INFINITE);
        int n = recv(instrument_sock, recvBuffer, sizeof(recvBuffer) - 1, 0);
        if (n > 0) {
            recvBuffer[n] = '\0';
            double resultValue = atof(recvBuffer);
            
            EnterCriticalSection(&cs);
            if (resultValue == pendingValue) {
                currentState.freq = resultValue;
                printf("\n >> Success! Frequency updated to %.2f Hz\n", resultValue);
            }
            else {
                printf("\n Error! Value Mismatch.\n");
            }
            LeaveCriticalSection(&cs);
        }
    }
    QueryPerformanceCounter(&end);
    double latency = (double)(end.QuadPart - start.QuadPart) * 1000.0 / freq.QuadPart;
    printf("Send Latency : %.3f ms\n", latency);

}


